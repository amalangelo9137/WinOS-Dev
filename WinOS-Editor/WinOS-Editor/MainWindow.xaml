<Window x:Name="MainWindow1" x:Class="WinOS_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinOS Engine Editor" Height="1079.7" Width="1920" Background="#1E1E1E">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Hierarchy" Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="HIERARCHY" Foreground="Gray" Margin="10,5" FontWeight="Bold"/>
                <TreeView x:Name="HierarchyTree" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0" SelectedItemChanged="HierarchyTree_SelectedItemChanged">
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Create Empty" Click="CreateEmpty_Click"/>
                            <MenuItem Header="Create Square" Click="CreateSquare_Click"/>
                            <Separator/>
                            <MenuItem Header="Delete" Click="DeleteObject_Click" Foreground="Red"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#2D2D30">
            <Canvas x:Name="SceneCanvas" Background="#1E1E1E" Width="1280" Height="720" HorizontalAlignment="Center" VerticalAlignment="Center">
            </Canvas>
        </Grid>

        <Border x:Name="Inspector" Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="InspectorPanel" Margin="15"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>