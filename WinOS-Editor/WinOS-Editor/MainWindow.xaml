<Window x:Class="WinOS_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinOS Editor"
        Width="1560"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        Background="#0F1720"
        Foreground="#F4F8FC"
        Icon="/WinOS-Logo.png">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="ApplicationCommands.Open" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed" />
    </Window.CommandBindings>
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0E1825" />
            <Setter Property="Foreground" Value="#F4F8FC" />
            <Setter Property="BorderBrush" Value="#30495F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="#F4F8FC" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1C3247" />
            <Setter Property="Foreground" Value="#F4F8FC" />
            <Setter Property="BorderBrush" Value="#36516A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0E1825" />
            <Setter Property="Foreground" Value="#F4F8FC" />
            <Setter Property="BorderBrush" Value="#30495F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#142131" />
            <Setter Property="Foreground" Value="#F4F8FC" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0E1825" />
            <Setter Property="Foreground" Value="#F4F8FC" />
            <Setter Property="BorderBrush" Value="#30495F" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F8FC" />
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#24374A" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Margin="0,0,14,0" Padding="16" Background="#142131" BorderBrush="#24374A" BorderThickness="1" CornerRadius="14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="App Package Authoring" />
                    <TextBlock Margin="0,6,0,0" Foreground="#9DB4C8" Text="Flat scene authoring with alias-based .wdexe export straight into the WinOS virtual drive." TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Document" />
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Foreground="#9DB4C8" Text="Name" />
                            <TextBox Margin="0,4,0,0" Text="{Binding Document.Name, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Foreground="#9DB4C8" Text="Package Alias" />
                            <TextBox Margin="0,4,0,0" Text="{Binding Document.PackageAlias, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Foreground="#9DB4C8" Text="Canvas Width" />
                            <TextBox Margin="0,4,0,0" Text="{Binding Document.CanvasWidth, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Foreground="#9DB4C8" Text="Canvas Height" />
                            <TextBox Margin="0,4,0,0" Text="{Binding Document.CanvasHeight, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <Button Margin="0,0,8,8" Padding="10,8" Click="Open_Click" Content="Open .wdexe" />
                        <Button Margin="0,0,0,8" Padding="10,8" Click="Export_Click" Content="Export Package" />
                        <Button Margin="0,0,8,8" Padding="10,8" Click="AddPanel_Click" Content="Add Panel" />
                        <Button Margin="0,0,0,8" Padding="10,8" Click="AddLabel_Click" Content="Add Label" />
                        <Button Margin="0,0,8,8" Padding="10,8" Click="AddButton_Click" Content="Add Button" />
                        <Button Margin="0,0,0,8" Padding="10,8" Click="AddSlider_Click" Content="Add Slider" />
                        <Button Margin="0,0,8,8" Padding="10,8" Click="AddTextField_Click" Content="Add Text Field" />
                        <Button Margin="0,0,0,8" Padding="10,8" Click="AddImage_Click" Content="Add Image" />
                        <Button Margin="0,0,8,0" Padding="10,8" Click="DeleteElement_Click" Content="Delete Selected" />
                    </UniformGrid>

                    <TextBlock Foreground="#9DB4C8" Text="Tip: Ctrl+O imports a .wdexe package and its asset references." TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Elements" />
                    <ListBox Margin="0,8,0,0"
                             ItemsSource="{Binding Document.Elements}"
                             SelectedItem="{Binding SelectedElement, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             Background="#0E1825"
                             BorderBrush="#24374A"
                             MinHeight="280" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="0,0,14,0" Padding="16" Background="#101926" BorderBrush="#24374A" BorderThickness="1" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Live Preview" />
                    <TextBlock Margin="0,6,0,0" Foreground="#9DB4C8" Text="The preview reads the same document model that exports to the binary runtime package." TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Background="#0B1118" BorderBrush="#24374A" BorderThickness="1" CornerRadius="12" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="#9DB4C8" Text="Drag regions are green by default in the sample so you can verify hit areas quickly." />
                        <Viewbox Grid.Row="1" Margin="0,16,0,0" Stretch="Uniform">
                            <Border Background="#081019" Padding="18" CornerRadius="8">
                                <Canvas x:Name="PreviewCanvas"
                                        Width="{Binding Document.CanvasWidth}"
                                        Height="{Binding Document.CanvasHeight}"
                                        Background="#0F1720" />
                            </Border>
                        </Viewbox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Padding="16" Background="#142131" BorderBrush="#24374A" BorderThickness="1" CornerRadius="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Inspector" />
                    <TextBlock Margin="0,6,0,14" Foreground="#9DB4C8" Text="The kernel consumes these values directly when it parses the exported .wdexe package." TextWrapping="Wrap" />

                    <StackPanel IsEnabled="{Binding HasSelectedElement}">
                        <TextBlock FontWeight="SemiBold" Text="Element" />
                        <Grid Margin="0,8,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Id" />
                                <TextBox Margin="0,4,0,0" IsReadOnly="True" Text="{Binding SelectedElement.Id}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="#9DB4C8" Text="Parent Id" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.ParentId, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Foreground="#9DB4C8" Text="Type" />
                        <ComboBox Margin="0,4,0,10"
                                  ItemsSource="{Binding ElementTypes}"
                                  SelectedItem="{Binding SelectedElement.Type, Mode=TwoWay}" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="X" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.X, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Y" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.Y, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="#9DB4C8" Text="Z" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.ZIndex, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Width" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.Width, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="#9DB4C8" Text="Height" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.Height, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Foreground="#9DB4C8" Text="Text" />
                        <TextBox Margin="0,4,0,10" Text="{Binding SelectedElement.Text, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#9DB4C8" Text="Asset Path" />
                        <TextBox Margin="0,4,0,10" Text="{Binding SelectedElement.AssetPath, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Value" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.Value, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Min" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.MinValue, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="#9DB4C8" Text="Max" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.MaxValue, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Background" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.BackgroundColorHex, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Foreground="#9DB4C8" Text="Foreground" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.ForegroundColorHex, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="#9DB4C8" Text="Border" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedElement.BorderColorHex, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Margin="0,0,0,6" IsChecked="{Binding SelectedElement.IsVisible}" Content="Visible" />
                        <CheckBox Margin="0,0,0,6" IsChecked="{Binding SelectedElement.IsInteractive}" Content="Interactive" />
                        <CheckBox Margin="0,0,0,6" IsChecked="{Binding SelectedElement.IsDraggableRegion}" Content="Draggable Region" />
                        <CheckBox Margin="0,0,0,6" IsChecked="{Binding SelectedElement.HasWindowFrame}" Content="Window Frame" />
                        <CheckBox Margin="0,0,0,16" IsChecked="{Binding SelectedElement.ClipsChildren}" Content="Clip Children" />
                    </StackPanel>

                    <Separator Margin="0,6,0,14" />

                    <StackPanel IsEnabled="{Binding HasSelectedElement}">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="Events" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Margin="0,0,8,0" Padding="8,4" Click="AddEvent_Click" Content="Add Event" />
                                <Button Padding="8,4" Click="RemoveEvent_Click" Content="Remove Event" />
                            </StackPanel>
                        </DockPanel>

                        <ListBox ItemsSource="{Binding SelectedElement.Events}"
                                 SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                 DisplayMemberPath="DisplayName"
                                 Background="#0E1825"
                                 BorderBrush="#24374A"
                                 MinHeight="120" />

                        <StackPanel Margin="0,12,0,0" IsEnabled="{Binding HasSelectedEvent}">
                            <TextBlock Foreground="#9DB4C8" Text="Event Type" />
                            <ComboBox Margin="0,4,0,12"
                                      ItemsSource="{Binding EventTypes}"
                                      SelectedItem="{Binding SelectedEvent.EventType, Mode=TwoWay}" />

                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="Bindings" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Margin="0,0,8,0" Padding="8,4" Click="AddBinding_Click" Content="Add Binding" />
                                    <Button Padding="8,4" Click="RemoveBinding_Click" Content="Remove Binding" />
                                </StackPanel>
                            </DockPanel>

                            <ListBox ItemsSource="{Binding SelectedEvent.Bindings}"
                                     SelectedItem="{Binding SelectedBinding, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayName"
                                     Background="#0E1825"
                                     BorderBrush="#24374A"
                                     MinHeight="120" />

                            <StackPanel Margin="0,12,0,0" IsEnabled="{Binding HasSelectedBinding}">
                                <TextBlock Foreground="#9DB4C8" Text="Action" />
                                <ComboBox Margin="0,4,0,10"
                                          ItemsSource="{Binding ActionTypes}"
                                          SelectedItem="{Binding SelectedBinding.ActionType, Mode=TwoWay}" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Foreground="#9DB4C8" Text="Target Element Id" />
                                        <TextBox Margin="0,4,0,0" Text="{Binding SelectedBinding.TargetElementId, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Foreground="#9DB4C8" Text="Property" />
                                        <ComboBox Margin="0,4,0,0"
                                                  ItemsSource="{Binding PropertyTypes}"
                                                  SelectedItem="{Binding SelectedBinding.PropertyType, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Foreground="#9DB4C8" Text="Int Value" />
                                        <TextBox Margin="0,4,0,0" Text="{Binding SelectedBinding.IntValue, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Foreground="#9DB4C8" Text="Color" />
                                        <TextBox Margin="0,4,0,0" Text="{Binding SelectedBinding.ColorHex, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Foreground="#9DB4C8" Text="String Value" />
                                <TextBox Margin="0,4,0,0" Text="{Binding SelectedBinding.StringValue, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,14,0,0" Padding="14,10" Background="#101926" BorderBrush="#24374A" BorderThickness="1" CornerRadius="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding StatusMessage}" />
                <TextBlock HorizontalAlignment="Right" Foreground="#9DB4C8" Text="{Binding Document.PackageAlias, StringFormat=Exports update Run\\VirtualDrive\\{0} and regenerate index.wfs.}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
